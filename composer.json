{
    "name": "voila/cms",
    "type": "project",
    "description": "voila-cms starter kit — PHP vitrine sites",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "intervention/image": "^2.7",
        "league/flysystem": "^3.0",
        "league/flysystem-local": "^3.0",
        "league/glide": "^2.3",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Modules\\Actualites\\": "app/modules/actualites/",
            "App\\Modules\\Partenaires\\": "app/modules/partenaires/",
            "App\\Modules\\Equipe\\": "app/modules/equipe/",
            "App\\Modules\\Temoignages\\": "app/modules/temoignages/",
            "App\\Modules\\Faq\\": "app/modules/faq/",
            "App\\Modules\\Documents\\": "app/modules/documents/",
            "App\\Modules\\Services\\": "app/modules/services/"
        },
        "files": ["app/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {"Tests\\": "tests/"}
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse app --level=6",
        "migrate": "php scripts/migrate.php",
        "serve": "php -S localhost:8000 -t public/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
