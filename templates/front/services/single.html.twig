{% extends 'layouts/base.html.twig' %}
{% block content %}
<article class="mx-auto max-w-3xl px-4 py-16">
    <nav class="text-sm text-slate-500 mb-4">
        <a href="/services" class="hover:text-primary">← Tous les services</a>
    </nav>
    <h1 class="font-display text-4xl font-bold mb-4">{{ row.titre }}</h1>
    {% if row.description_courte %}
    <p class="text-xl text-slate-600 leading-relaxed mb-6">{{ row.description_courte }}</p>
    {% endif %}
    {% if row.image %}
    <img src="/{{ row.image }}" alt="{{ row.titre }}" class="w-full h-auto rounded mb-8">
    {% endif %}
    {% if row.contenu %}
    <div class="prose prose-slate max-w-none">
        {{ row.contenu|raw }}
    </div>
    {% endif %}
</article>
{% endblock %}
